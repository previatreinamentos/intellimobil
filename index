  <script>
    // Menu mobile toggle
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));

    // 1. FILTRAR CATÁLOGO DE CURSOS
    function filterCatalog(category) {
      const buttons = document.querySelectorAll('.cat-filter-btn');
      buttons.forEach(btn => {
        btn.classList.remove('active', 'bg-brand-orange', 'text-white');
        btn.classList.add('bg-brand-dark', 'text-brand-gray');
      });

      // Ativa o botão correspondente
      event.target.classList.add('active', 'bg-brand-orange', 'text-white');
      event.target.classList.remove('bg-brand-dark', 'text-brand-gray');

      const cards = document.querySelectorAll('.catalog-item-card');
      cards.forEach(card => {
        if (category === 'Todos' || card.getAttribute('data-category') === category) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    }

    // 2. RAMIFICAÇÃO INTERATIVA DE CENÁRIO LXP
    function triggerLXPScenario(option, text) {
      const scenarioTextElement = document.getElementById('scenario-text');
      const attention = document.getElementById('metric-attention');
      const reaction = document.getElementById('metric-reaction');
      const compliance = document.getElementById('metric-compliance');

      if (option === 'A') {
        scenarioTextElement.textContent = `"Excelente escolha. O freio motor reduziu a velocidade de forma gradual, mantendo a estabilidade nas rodas traseiras e evitando aquecimento."`;
        attention.textContent = "99.1%";
        reaction.textContent = "1.0s";
        compliance.textContent = "Excelente";
        compliance.className = "text-lg font-bold font-outfit text-emerald-400";
      } else {
        scenarioTextElement.textContent = `"Atenção! A frenagem brusca com pista úmida iniciou o travamento de rodas. O sistema ABS tentou compensar, mas houve leve desvio."`;
        attention.textContent = "84.5%";
        reaction.textContent = "1.8s";
        compliance.textContent = "Risco Médio";
        compliance.className = "text-lg font-bold font-outfit text-brand-orange";
      }
    }

    // 3. TOASTS E LEADS
    function triggerLeadConversion() {
      const form = document.getElementById('contact-commercial-form');
      const toast = document.getElementById('contact-success-toast');

      form.classList.add('hidden');
      toast.classList.remove('hidden');

      setTimeout(() => {
        form.reset();
        form.classList.remove('hidden');
        toast.classList.add('hidden');
      }, 5000);
    }

    // Modal Controle
    function openModalCurso(title) {
      document.getElementById('course-details-modal').classList.remove('hidden');
      document.getElementById('modal-course-title').textContent = title;
    }

    function closeModalCurso() {
      document.getElementById('course-details-modal').classList.add('hidden');
    }

    // Lógica do Painel de Ajuda Flutuante
    const guideBtn = document.getElementById('guide-toggle-btn');
    const guideDrawer = document.getElementById('guide-drawer');
    const guideClose = document.getElementById('guide-close-btn');
    const highlightBtn = document.getElementById('guide-highlight-btn');

    guideBtn.addEventListener('click', () => {
      guideDrawer.classList.toggle('hidden');
    });

    guideClose.addEventListener('click', () => {
      guideDrawer.classList.add('hidden');
    });

    // Função de Brilho nos links indicados
    highlightBtn.addEventListener('click', () => {
      const targets = [
        'nav-blog', 'nav-podcast', 'nav-aluno',
        'hero-blog', 'hero-podcast', 
        'mobile-blog', 'mobile-podcast', 'mobile-aluno',
        'footer-blog', 'footer-podcast'
      ];

      let isGlowOn = false;

      targets.forEach(id => {
        const el = document.getElementById(id);
        if (el) {
          el.classList.toggle('glow-highlight');
          if (el.classList.contains('glow-highlight')) {
            isGlowOn = true;
          }
        }
      });

      if (isGlowOn) {
        highlightBtn.textContent = '🛑 DESATIVAR DESTAQUES';
        highlightBtn.classList.remove('bg-brand-gradient');
        highlightBtn.classList.add('bg-red-600');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        highlightBtn.textContent = '💡 DESTACAR LINKS';
        highlightBtn.classList.remove('bg-red-600');
        highlightBtn.classList.add('bg-brand-gradient');
      }
    });
  </script>
</body>
</html>
